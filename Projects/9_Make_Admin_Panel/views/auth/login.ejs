<!DOCTYPE html>
<html>
<head>
  <title>Login</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 flex justify-center items-center h-screen">

<form action="/login" method="POST" class="bg-white p-8 rounded-lg shadow-md w-96">

  <h2 class="text-3xl font-bold mb-6 text-center">Admin Login</h2>

  <input
    type="email"
    name="email"
    placeholder="Email"
    class="w-full border p-3 mb-4 rounded"
  />

  <input
    type="password"
    name="password"
    placeholder="Password"
    class="w-full border p-3 mb-4 rounded"
  />

  <button class="bg-blue-600 text-white w-full py-3 rounded">
    Login
  </button>

</form>

</body>
</html>