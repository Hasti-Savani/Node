<!DOCTYPE html>
<html>
<head>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body>

<%- include("partials/navbar") %>

<div class="container mx-auto p-6">

<form
  action="/products/add"
  method="POST"
  class="bg-white p-5 rounded shadow w-1/2 mx-auto"
>

<input
  type="text"
  name="title"
  placeholder="Product Title"
  class="w-full border p-2 mb-4"
/>

<input
  type="number"
  name="price"
  placeholder="Price"
  class="w-full border p-2 mb-4"
/>

<textarea
  name="description"
  placeholder="Description"
  class="w-full border p-2 mb-4"
></textarea>

<select
  name="category"
  class="w-full border p-2 mb-4"
>

<% categories.forEach(category => { %>

<option value="<%= category._id %>">
  <%= category.name %>
</option>

<% }) %>

</select>

<button class="bg-blue-500 text-white px-5 py-2 rounded">
  Add Product
</button>

</form>

</div>

</body>
</html>