<!DOCTYPE html>
<html>
<head>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body>

<%- include("partials/navbar") %>

<div class="container mx-auto p-6">

<h1 class="text-3xl font-bold mb-5">
  Categories
</h1>

<form
  action="/categories/add"
  method="POST"
  class="mb-5 flex gap-3"
>

<input
  type="text"
  name="name"
  placeholder="Category Name"
  class="border p-2"
/>

<button class="bg-green-500 text-white px-5 rounded">
  Add
</button>

</form>

<div class="space-y-3">

<% categories.forEach(category => { %>

<div class="bg-white p-4 rounded shadow flex justify-between">

<h2><%= category.name %></h2>

<form
  action="/categories/<%= category._id %>?_method=DELETE"
  method="POST"
>

<button class="bg-red-500 text-white px-3 py-1 rounded">
  Delete
</button>

</form>

</div>

<% }) %>

</div>

</div>

</body>
</html>