<!DOCTYPE html>
<html>
<head>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<div class="flex justify-center items-center h-screen">

<form
  action="/login"
  method="POST"
  class="bg-white p-8 rounded shadow-md w-96"
>

<h2 class="text-3xl font-bold mb-5 text-center">
  Login
</h2>

<input
  type="email"
  name="email"
  placeholder="Email"
  class="w-full border p-2 mb-4"
/>

<input
  type="password"
  name="password"
  placeholder="Password"
  class="w-full border p-2 mb-4"
/>

<button
  class="bg-blue-500 text-white w-full p-2 rounded"
>
  Login
</button>

</form>

</div>

</body>
</html>